# iOS simulator / web on same machine:
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Android emulator:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000

# Physical devices need your computer or deployed API host, for example:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.50:8000
# EXPO_PUBLIC_API_BASE_URL=https://api.your-domain.example
