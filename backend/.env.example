THAI_TONES_ENV=development
THAI_TONES_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006
THAI_TONES_CORS_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1):[0-9]+
THAI_TONES_MAX_AUDIO_UPLOAD_BYTES=8388608
THAI_TONES_ALLOWED_AUDIO_CONTENT_TYPES=audio/m4a,audio/mp4,audio/mpeg,audio/wav,audio/x-wav,audio/aac,audio/webm,audio/ogg,video/webm,application/octet-stream
